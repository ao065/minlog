---
import { SITE_NAME } from "../consts";
---

<header class="header">
  <h1 class="heading">
    <a href="/" class="link">{SITE_NAME}</a>
  </h1>
</header>

<style>
  .header {
    display: flex; /* stylelint-disable defensive-css/require-flex-wrap */
    align-items: center;

    max-inline-size: var(--content-width);
    margin-block-start: 2rem;
    margin-inline: auto;
    padding-inline: 1rem;
  }

  .heading {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .link {
    color: var(--text-primary);
  }
</style>
