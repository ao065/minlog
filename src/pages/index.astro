---
import ArticleItem from "../components/ArticleItem.astro";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Post {
  title: string;
  pubDate: Date;
  link: string;
}
const posts: Post[] = [
  {
    title: "Astroでブログを作った",
    pubDate: new Date("2026-06-18"),
    link: "/blog/astro-blog-setup",
  },
  {
    title: "Tailwind CSSで知っておくと便利なテクニック5選",
    pubDate: new Date("2026-05-30"),
    link: "/blog/tailwind-tips",
  },
  {
    title: "TypeScriptのジェネリクスを図解で理解する",
    pubDate: new Date("2026-05-12"),
    link: "/blog/typescript-generics",
  },
  {
    title: "useEffectでやりがちな3つのミスと対策",
    pubDate: new Date("2026-04-27"),
    link: "/blog/react-useeffect-pitfalls",
  },
  {
    title: "git rebaseとmergeの使い分けを整理した",
    pubDate: new Date("2026-04-03"),
    link: "/blog/git-rebase-vs-merge",
  },
];
---

<Layout>
  <Header />
  <main>
    <div class="articles">
      <h2 class="heading">Articles</h2>
      {
        posts.map((post) => (
          <ArticleItem
            title={post.title}
            pubDate={post.pubDate}
            link={post.link}
          />
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .articles {
    display: grid;
    gap: 1rem;

    max-inline-size: var(--content-width);
    margin-block-start: 2rem;
    margin-inline: auto;
    padding-inline: 1rem;
  }

  .heading {
    border-block-end: 1px solid var(--text-secondary);
    font-size: 1rem;
    font-weight: 700;
  }
</style>
